<script setup lang="ts">
import { ref, onMounted, onUnmounted } from 'vue'
import { useRouter } from 'vue-router'

// 导入PPT预览图片（根据实际图片文件名调整）
import businessImg from '@/assets/ppt-previews/business.jpg'
import productImg from '@/assets/ppt-previews/product.jpg'
import reportImg from '@/assets/ppt-previews/report.jpg'
