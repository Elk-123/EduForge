import fundImg from '@/assets/ppt-previews/fund.jpg'
import yearlyImg from '@/assets/ppt-previews/yearly.jpg'
import teamImg from '@/assets/ppt-previews/team.jpg'
import projectImg from '@/assets/ppt-previews/project.jpg'
import marketImg from '@/assets/ppt-previews/market.jpg'
import strategyImg from '@/assets/ppt-previews/strategy.jpg'
import trainingImg from '@/assets/ppt-previews/training.jpg'
import dataImg from '@/assets/ppt-previews/data.jpg'

const router = useRouter()
const username = ref('')
const password = ref('')
const showPassword = ref(false)
const isLoggingIn = ref(false)
const scrollY = ref(0)
let animationFrame: number

// PPT模板数据 - 添加imgUrl字段指向图片
const waterfallItems = [
  // 第一组
  { 
    title: '商业计划书',
    type: 'PPT模板',
    imgUrl: businessImg, // 图片路径
    icon: 'icon-xinjian_PPTyanshiwengao',
    class: 'item-business'
  },
  { 
    title: '产品发布',
    type: '演示文稿',
    imgUrl: productImg,
    icon: 'icon-wendang',
    class: 'item-product'
  },
  { 
    title: '季度汇报',
    type: 'PPT模板',
    imgUrl: reportImg,
    icon: 'icon-mobansheji',
    class: 'item-report'
  },
  { 
    title: '营销方案',
    type: '演示文稿',
    imgUrl: marketingImg,
    icon: 'icon-daoru',
    class: 'item-marketing'
  },
  // 第二组
  { 
    title: '融资路演',
    type: 'PPT模板',
    imgUrl: fundImg,
    icon: 'icon-xinjian_PPTyanshiwengao',
    class: 'item-fund'
  },
  { 
    title: '年度总结',
    type: '演示文稿',
    imgUrl: yearlyImg,
    icon: 'icon-wendang',
    class: 'item-yearly'
  },
  { 
    title: '团队介绍',
    type: 'PPT模板',
    imgUrl: teamImg,
    icon: 'icon-mobansheji',
    class: 'item-team'
  },
  { 
    title: '项目规划',
    type: '演示文稿',
    imgUrl: projectImg,
    icon: 'icon-daoru',
    class: 'item-project'
  },
  // 第三组
  { 
    title: '市场分析',
    type: 'PPT模板',
    imgUrl: marketImg,
    icon: 'icon-xinjian_PPTyanshiwengao',
    class: 'item-market'
  },
  { 
    title: '战略规划',
    type: '演示文稿',
    imgUrl: strategyImg,
    icon: 'icon-wendang',
    class: 'item-strategy'
  },
  { 
    title: '培训课件',
    type: 'PPT模板',
    imgUrl: trainingImg,
    icon: 'icon-mobansheji',
    class: 'item-training'
  },
  { 
    title: '数据分析',
    type: '演示文稿',
    imgUrl: dataImg,
    icon: 'icon-daoru',
    class: 'item-data'
  }
]

const validUsers = [
  { username: 'admin', password: 'admin123' },
  { username: 'user', password: 'user123' },
  { username: 'test', password: 'test123' }
]

// 瀑布流动画
const startWaterfallScroll = () => {
  const scroll = () => {
    scrollY.value -= 0.3
    if (scrollY.value < -2000) {
      scrollY.value = 0
    }
    animationFrame = requestAnimationFrame(scroll)
  }
  animationFrame = requestAnimationFrame(scroll)
}

onMounted(() => {
  startWaterfallScroll()
})

onUnmounted(() => {
  if (animationFrame) {
    cancelAnimationFrame(animationFrame)
  }
})

const handleLogin = async () => {
  if (!username.value || !password.value) {
    alert('请输入账号和密码')
    return
  }

  isLoggingIn.value = true
  
  try {
    await new Promise(resolve => setTimeout(resolve, 800))
    
    const user = validUsers.find(
      u => u.username === username.value && u.password === password.value
    )
    
    if (user) {
      localStorage.setItem('isLoggedIn', 'true')
      localStorage.setItem('username', username.value)
      router.push('/home')
    } else {
      alert('用户名或密码错误')
    }
  } catch (error) {
    alert('登录失败，请重试')
  } finally {
    isLoggingIn.value = false
  }
}

const handleForgot = () => {
  alert('请联系管理员重置密码，或使用测试账号：\nadmin/admin123\nuser/user123\ntest/test123')
}

const goToRegister = () => {
  router.push('/register')
}

const handleHelp = () => {
  alert('请输入您的账号和密码进行登录\n测试账号：admin/admin123')
}
